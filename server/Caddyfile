secureshare-relay.duckdns.org {
    # Security headers (global defaults)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-origin"
        -Server
    }

    # Health check endpoint (GET only)
    @health_get {
        method GET
        path /health
    }
    handle @health_get {
        header Content-Security-Policy "default-src 'none'"
        respond "ok" 200
    }

    # App download — static files from /downloads
    handle /download/* {
        header Content-Security-Policy "default-src 'none'"
        header Content-Disposition "attachment"
        header Cache-Control "no-cache"
        uri strip_prefix /download
        root * /downloads
        file_server
    }

    # WebSocket relay — proxy only WS connections
    @websocket {
        header Connection *Upgrade*
        header Upgrade    websocket
    }
    handle @websocket {
        reverse_proxy relay:8765 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Landing page — static site (everything else)
    handle {
        header Content-Security-Policy "default-src 'none'; style-src 'unsafe-inline'; img-src 'self'"
        root * /www
        file_server
    }
}
