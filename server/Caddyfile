secureshare-relay.duckdns.org {
	# Security headers (global defaults)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		-Server
	}

	# Health check endpoint — proxy to relay
	handle /health {
		header Content-Security-Policy "default-src 'none'"
		reverse_proxy relay:8766
	}

	# Public version endpoint — cacheable, no auth needed
	handle /api/version {
		header Content-Security-Policy "default-src 'none'"
		header Cache-Control "public, max-age=300"
		reverse_proxy relay:8766
	}

	# API endpoints — proxy to relay (crash reports, telemetry, admin)
	handle /api/* {
		header Content-Security-Policy "default-src 'none'"
		header Cache-Control "no-store"
		reverse_proxy relay:8766 {
			header_up X-Real-IP {remote_host}
		}
	}

	# Admin dashboard — static page + API calls
	handle /admin {
		header Content-Security-Policy "default-src 'self'; script-src 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'unsafe-inline'; connect-src 'self'; img-src 'self' data:"
		root * /www
		rewrite * /admin.html
		file_server
	}

	# App download — redirect to GitHub Releases (saves VPS bandwidth)
	handle /download/SecureShare.zip {
		redir https://github.com/artmarchenko/SecureShare/releases/latest/download/SecureShare.zip 302
	}
	handle /download/SecureShare-linux-x64.tar.gz {
		redir https://github.com/artmarchenko/SecureShare/releases/latest/download/SecureShare-linux-x64.tar.gz 302
	}
	handle /download/* {
		redir https://github.com/artmarchenko/SecureShare/releases/latest 302
	}

	# WebSocket relay — proxy only WS connections
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @websocket {
		reverse_proxy relay:8765 {
			header_up X-Real-IP {remote_host}
		}
	}

	# Custom 404 error page
	handle_errors {
		@404 expression {err.status_code} == 404
		handle @404 {
			root * /www
			rewrite * /404.html
			file_server
		}
	}

	# Landing page — static site (everything else)
	handle {
		header Content-Security-Policy "default-src 'none'; script-src 'self'; style-src 'unsafe-inline'; img-src 'self'; connect-src 'self'; base-uri 'none'; form-action 'none'"
		# Cache static assets (images, JS, icons)
		@static path *.png *.jpg *.jpeg *.gif *.webp *.ico *.js *.css *.svg *.woff2
		header @static Cache-Control "public, max-age=604800, immutable"
		# HTML — no cache (always fresh)
		@html path *.html /
		header @html Cache-Control "no-cache"
		# Compression
		encode gzip
		root * /www
		file_server
	}
}
